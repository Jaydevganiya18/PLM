generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ENGINEERING
  APPROVER
  OPERATIONS
}

enum Status {
  ACTIVE
  ARCHIVED
}

enum EcoType {
  PRODUCT
  BOM
}

enum EcoStatus {
  DRAFT
  IN_PROGRESS
  REJECTED
  APPLIED
  CANCELLED
}

enum ApproverRole {
  ADMIN
  APPROVER
}

enum ApprovalAction {
  APPROVED
  REJECTED
  VALIDATED
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  password_hash    String
  role             Role
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  created_products Product[]
  created_product_versions ProductVersion[]
  uploaded_attachments ProductAttachment[]
  created_boms     Bom[]
  created_bom_versions BomVersion[]
  created_eco_stages EcoStage[]
  requested_ecos   Eco[]
  eco_approvals    EcoApproval[]
  eco_stage_history EcoStageHistory[]
  audit_logs       AuditLog[]

  @@map("users")
}

// ----------------------------------------------------
// PRODUCT & VERSIONS
// ----------------------------------------------------
model Product {
  id                 Int       @id @default(autoincrement())
  product_code       String    @unique
  status             Status    @default(ACTIVE)
  current_version_id Int?      // Points to ProductVersion.id
  created_by         Int
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  archived_at        DateTime?

  creator            User      @relation(fields: [created_by], references: [id])
  current_version    ProductVersion? @relation("ProductCurrentVersion", fields: [current_version_id], references: [id])

  versions           ProductVersion[] @relation("ProductVersions")
  boms               Bom[]
  ecos               Eco[]
  bom_components     BomComponent[]

  @@map("products")
}

model ProductVersion {
  id                 Int       @id @default(autoincrement())
  product_id         Int
  version_no         Int
  name               String
  sale_price         Decimal   @db.Decimal(12, 2)
  cost_price         Decimal   @db.Decimal(12, 2)
  effective_date     DateTime?
  status             Status    @default(ACTIVE)
  created_via_eco_id Int?
  created_by         Int
  created_at         DateTime  @default(now())
  archived_at        DateTime?

  product            Product   @relation("ProductVersions", fields: [product_id], references: [id])
  active_in_product  Product[] @relation("ProductCurrentVersion")
  creator            User      @relation(fields: [created_by], references: [id])
  created_via_eco    Eco?      @relation("ProductVersionEco", fields: [created_via_eco_id], references: [id])
  
  attachments        ProductAttachment[]
  ecos_as_source     Eco[]     @relation("SourceProductVersion")

  @@unique([product_id, version_no])
  @@map("product_versions")
}

model ProductAttachment {
  id                 Int       @id @default(autoincrement())
  product_version_id Int
  file_name          String
  file_url           String
  uploaded_by        Int
  created_at         DateTime  @default(now())

  product_version    ProductVersion @relation(fields: [product_version_id], references: [id])
  uploader           User           @relation(fields: [uploaded_by], references: [id])

  @@map("product_attachments")
}

// ----------------------------------------------------
// BOM & VERSIONS
// ----------------------------------------------------
model Bom {
  id                 Int       @id @default(autoincrement())
  bom_code           String    @unique
  product_id         Int
  status             Status    @default(ACTIVE)
  current_version_id Int?
  created_by         Int
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  archived_at        DateTime?

  product            Product   @relation(fields: [product_id], references: [id])
  creator            User      @relation(fields: [created_by], references: [id])
  current_version    BomVersion? @relation("BomCurrentVersion", fields: [current_version_id], references: [id])

  versions           BomVersion[] @relation("BomVersions")
  ecos               Eco[]

  @@map("boms")
}

model BomVersion {
  id                 Int       @id @default(autoincrement())
  bom_id             Int
  version_no         Int
  status             Status    @default(ACTIVE)
  effective_date     DateTime?
  created_via_eco_id Int?
  created_by         Int
  created_at         DateTime  @default(now())
  archived_at        DateTime?

  bom                Bom       @relation("BomVersions", fields: [bom_id], references: [id])
  active_in_bom      Bom[]     @relation("BomCurrentVersion")
  creator            User      @relation(fields: [created_by], references: [id])
  created_via_eco    Eco?      @relation("BomVersionEco", fields: [created_via_eco_id], references: [id])

  components         BomComponent[]
  operations         BomOperation[]
  ecos_as_source     Eco[]     @relation("SourceBomVersion")

  @@unique([bom_id, version_no])
  @@map("bom_versions")
}

model BomComponent {
  id                   Int       @id @default(autoincrement())
  bom_version_id       Int
  line_no              Int
  component_product_id Int
  quantity             Decimal   @db.Decimal(12, 4)
  uom                  String
  created_at           DateTime  @default(now())

  bom_version          BomVersion @relation(fields: [bom_version_id], references: [id])
  component_product    Product    @relation(fields: [component_product_id], references: [id])

  @@unique([bom_version_id, line_no])
  @@map("bom_components")
}

model BomOperation {
  id                   Int       @id @default(autoincrement())
  bom_version_id       Int
  line_no              Int
  operation_name       String
  work_center          String
  duration_minutes     Decimal   @db.Decimal(10, 2)
  created_at           DateTime  @default(now())

  bom_version          BomVersion @relation(fields: [bom_version_id], references: [id])

  @@unique([bom_version_id, line_no])
  @@map("bom_operations")
}

// ----------------------------------------------------
// WORKFLOW (ECO)
// ----------------------------------------------------
model EcoStage {
  id                Int       @id @default(autoincrement())
  name              String    @unique
  sequence_no       Int       @unique
  approval_required Boolean
  is_start_stage    Boolean
  is_final_stage    Boolean
  is_active         Boolean   @default(true)
  created_by        Int
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  creator           User      @relation(fields: [created_by], references: [id])

  approval_rules    ApprovalRule[]
  ecos              Eco[]
  eco_approvals     EcoApproval[]
  history_from      EcoStageHistory[] @relation("FromStage")
  history_to        EcoStageHistory[] @relation("ToStage")

  @@map("eco_stages")
}

model ApprovalRule {
  id                Int       @id @default(autoincrement())
  stage_id          Int
  approver_role     ApproverRole
  min_approvals     Int       @default(1)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  stage             EcoStage  @relation(fields: [stage_id], references: [id])

  @@map("approval_rules")
}

model Eco {
  id                        Int       @id @default(autoincrement())
  eco_number                String    @unique
  title                     String
  eco_type                  EcoType
  product_id                Int
  bom_id                    Int?
  source_product_version_id Int?
  source_bom_version_id     Int?
  original_snapshot         Json?     // Keep JSON object
  proposed_changes          Json?     // Keep JSON object
  current_stage_id          Int?
  status                    EcoStatus @default(DRAFT)
  version_update            Boolean   @default(true)
  rejection_reason          String?   @db.Text
  effective_date            DateTime?
  requested_by              Int
  created_at                DateTime  @default(now())
  started_at                DateTime?
  submitted_at              DateTime?
  approved_at               DateTime?
  applied_at                DateTime?
  updated_at                DateTime  @updatedAt

  product                   Product   @relation(fields: [product_id], references: [id])
  bom                       Bom?      @relation(fields: [bom_id], references: [id])
  source_product_version    ProductVersion? @relation("SourceProductVersion", fields: [source_product_version_id], references: [id])
  source_bom_version        BomVersion?     @relation("SourceBomVersion", fields: [source_bom_version_id], references: [id])
  current_stage             EcoStage? @relation(fields: [current_stage_id], references: [id])
  requester                 User      @relation(fields: [requested_by], references: [id])

  approvals                 EcoApproval[]
  stage_history             EcoStageHistory[]
  audit_logs                AuditLog[]
  created_product_versions  ProductVersion[] @relation("ProductVersionEco")
  created_bom_versions      BomVersion[]     @relation("BomVersionEco")

  @@map("ecos")
}

model EcoApproval {
  id                Int       @id @default(autoincrement())
  eco_id            Int
  stage_id          Int
  approver_id       Int
  action            ApprovalAction
  comment           String?   @db.Text
  created_at        DateTime  @default(now())

  eco               Eco       @relation(fields: [eco_id], references: [id])
  stage             EcoStage  @relation(fields: [stage_id], references: [id])
  approver          User      @relation(fields: [approver_id], references: [id])

  @@map("eco_approvals")
}

model EcoStageHistory {
  id                Int       @id @default(autoincrement())
  eco_id            Int
  from_stage_id     Int?
  to_stage_id       Int?
  action            String
  acted_by          Int
  comment           String?   @db.Text
  created_at        DateTime  @default(now())

  eco               Eco       @relation(fields: [eco_id], references: [id])
  from_stage        EcoStage? @relation("FromStage", fields: [from_stage_id], references: [id])
  to_stage          EcoStage? @relation("ToStage", fields: [to_stage_id], references: [id])
  actor             User      @relation(fields: [acted_by], references: [id])

  @@map("eco_stage_history")
}

model AuditLog {
  id                Int       @id @default(autoincrement())
  user_id           Int?
  action            String
  affected_type     String
  affected_id       Int
  eco_id            Int?
  old_value         Json?
  new_value         Json?
  smart_summary     String?   @db.Text
  created_at        DateTime  @default(now())

  user              User?     @relation(fields: [user_id], references: [id])
  eco               Eco?      @relation(fields: [eco_id], references: [id])

  @@map("audit_logs")
}
